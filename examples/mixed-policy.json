{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOnly",
      "Effect": "Allow",
      "Action": ["ec2:DescribeInstances", "s3:GetObject"],
      "Resource": "*"
    },
    {
      "Sid": "RiskyWrite",
      "Effect": "Allow",
      "Action": ["ec2:TerminateInstances", "ec2:StartInstances"],
      "Resource": "*"
    }
  ]
}
