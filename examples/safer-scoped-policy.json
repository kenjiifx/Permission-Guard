{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ReadScoped",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Resource": ["arn:aws:s3:::team-bucket", "arn:aws:s3:::team-bucket/*"],
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "us-east-1"
        }
      }
    }
  ]
}
