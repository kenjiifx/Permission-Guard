{
  "name": "permissionguard",
  "version": "0.1.0",
  "description": "Local-first CLI to detect overly broad AWS IAM permissions and generate safer remediation suggestions.",
  "keywords": [
    "aws",
    "iam",
    "security",
    "cli",
    "least-privilege",
    "typescript"
  ],
  "homepage": "https://github.com/kenjiifx/Permission-Guard",
  "repository": {
    "type": "git",
    "url": "https://github.com/kenjiifx/Permission-Guard.git"
  },
  "license": "MIT",
  "author": "Moosa Alam",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "permissionguard": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts --help",
    "lint": "eslint src tests --ext .ts",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@aws-sdk/client-iam": "^3.1035.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "typescript-eslint": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
